# Telegram API Authentication
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Optional: Set TELEGRAM_SESSION directly if you already have a saved session string
TELEGRAM_SESSION=

# PostgreSQL Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=telegram_archive
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password

# S3-Compatible Storage Configuration (MinIO, AWS S3, CF R2, Backblaze B2)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio_admin_user
S3_SECRET_KEY=minio_admin_password
S3_BUCKET=telegram-archive-media

# Importer Configuration
CHANNELS=durov,telegram
IMPORT_CONCURRENCY=1
PORT=3000
